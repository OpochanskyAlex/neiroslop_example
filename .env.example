# Copy this to .env and fill in values before running docker-compose

# Local Docker development:
DATABASE_URL=postgresql://notes_user:notes_pass@db:5432/notes_db

# Production (Supabase connection string):
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_replace_with_64_char_hex

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60